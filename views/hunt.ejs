<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
  <head>
    <link rel="icon" href="/data/images/amongdemons.ico" type="image/x-icon">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% const demonName = getDemonName(currentPage); %>
    <title>Hunt Among Demons</title>
    <meta name="description" content="Hunt for these models as part of the founders collection. The NFTs are minted and transacted on Stargaze from the Cosmos ecosystem.">

    <!-- Page Metadata Thumbnail -->
    <meta property="og:image" content="<%= CONFIG.thumbnailsDir %><%= currentPage %>.png">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/data/main.css" rel="stylesheet">
  </head>
  <body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">
          <img src="/data/images/amongdemons_logo_250x250.png" alt="" class="d-inline-block align-middle me-2 logo-nav" style="width: 48px; height: 48px;">
          Among Demons
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="demonsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Demons</a>
              <ul class="dropdown-menu dropdown-menu-end" id="demonTypesDropdown">
                <% for (let i = 1; i <= CONFIG.demonNames.length; i++) { %>
                  <li><a class="dropdown-item" href="/demons/type/<%= i %>"><%= CONFIG.demonNames[i - 1] %></a></li>
                <% } %>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container my-4">
      
      <!-- Header Section: Navigation + Title + Subtitle -->
      <div class="d-flex justify-content-between align-items-center py-3 mb-4">
        <% if (currentPage > 1) { %>
          <a class="text-decoration-none ps-2" href="/demons/type/<%= currentPage - 1 %>" style="font-size: 2rem; line-height: 1;" aria-label="Previous page">&laquo;</a>
        <% } else { %>
          <div style="font-size: 2rem; line-height: 1;" class="ps-2">&nbsp;&nbsp;&nbsp;</div>
        <% } %>
        
        <div style="text-align: center;">
          <h1 class="display-4">Hunt <%= demonName %></h1>
          <p class="mb-0 text-muted m-0">Demon Type <%= currentPage %></p>
          <p class="small text-muted">Track and capture the demons in your hunt</p>
        </div>
        
        <% if (currentPage < totalPages) { %>
          <a class="text-decoration-none pe-2" href="/demons/type/<%= currentPage + 1 %>" style="font-size: 2rem; line-height: 1;" aria-label="Next page">&raquo;</a>
        <% } else { %>
          <div style="font-size: 2rem; line-height: 1;" class="pe-2">&nbsp;&nbsp;&nbsp;</div>
        <% } %>
      </div>

      <!-- Demons Grid -->
      <div class="row row-cols-3 g-3">
        <% for (let i = startImage; i <= endImage; i++) { %>
          <div class="col">
            <div class="card h-100">
              <% const rarity = getRarity(i); %>
              <img src="<%= CONFIG.imagesDir %><%= i %>.png" class="card-img-top" alt="<%= rarity %> - Hunt <%= demonName %>">
              <div class="card-body text-center">
                <h5 class="card-title m-0 ad-<%= rarity %>"><%= capitalize(rarity) %> - Hunt</h5>
                <p class="small text-muted mb-2">Demon Type <%= currentPage %></p>
              </div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Pagination -->
      <nav aria-label="Page navigation" class="my-4">
        <ul class="pagination justify-content-center flex-wrap gap-1 pagination-sm-responsive">
          <% for (let p = 1; p <= totalPages && p <= 11; p++) { %>
            <% if (p === currentPage) { %>
              <li class="page-item active" aria-current="page">
                <span class="page-link d-flex align-items-center justify-content-center">
                  <%= p %>
                </span>
              </li>
            <% } else { %>
              <li class="page-item"><a class="page-link d-flex align-items-center justify-content-center" href="/demons/type/<%= p %>"><%= p %></a></li>
            <% } %>
          <% } %>
        </ul>
      </nav>

    </main>

    <!-- Footer -->
    <footer class="py-3 my-4 border-top">
      <div class="container text-center text-body-secondary">
        <p>&copy; 2026 Among Demons. All rights reserved.</p>
      </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
