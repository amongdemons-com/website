<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
  <head>
    <link rel="icon" href="/data/images/amongdemons.ico" type="image/x-icon">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Demon Type <%= currentPage %> - Among Demons NFTs</title>
    <meta name="description" content="These models are part of the founders collection. The NFTs are minted and transacted on Stargaze from the Cosmos ecosystem.">

    <!-- Page Metadata Thumbnail -->
    <meta property="og:image" conten="/data/images/demons/thumbnails/<%= currentPage %>.png">
    
    <!-- Bootstrap Icons SVG - Required for Bootstrap Icon classes -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/data/main.css" rel="stylesheet">
  </head>
  <body>
    <%- include('components/navigation') %>

    <!-- Main Content -->
    <main class="container my-4">
      
      <!-- Header Section: Navigation + Title + Subtitle -->
      <div class="d-flex justify-content-between align-items-center py-3 mb-4">
        <a class="text-decoration-none ps-2" href="/demons/type/<%= currentPage - 1 %>" style="font-size: 2rem; line-height: 1;" aria-label="Previous">&laquo;</a>
        
        <div style="text-align: center;">
          <h1 class="display-4" id="demon-title"></h1>
          <p class="mb-0 text-muted m-0">Demon Type <span id="type-number"><%= currentPage %></span></p>
        </div>
        
        <a class="text-decoration-none pe-2" href="/demons/type/<%= currentPage + 1 %>" style="font-size: 2rem; line-height: 1;" aria-label="Next">&raquo;</a>
      </div>

      <!-- Demons Grid -->
      <div class="row row-cols-3 g-3" id="demons-grid"></div>

      <!-- Pagination -->
      <nav aria-label="Page navigation" class="my-4">
        <ul class="pagination justify-content-center flex-wrap gap-1 pagination-sm-responsive" id="pagination"></ul>
      </nav>

    </main>

    <!-- Footer -->
    <footer class="py-3 my-4 border-top">
      <div class="container text-center text-body-secondary">
        <p>&copy; 2026 Among Demons. All rights reserved.</p>
      </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Client-side data loading -->
    <script src="/data/js/index.js"></script>
  </body>
</html>