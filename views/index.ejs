<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% const demonName = getDemonName(currentPage); %>
    <title><%= demonName %> - Among Demons NFTs</title>
    <meta name="description" content="These models are part of the founders collection. The NFTs are minted and transacted on Stargaze from the Cosmos ecosystem.">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/data/main.css" rel="stylesheet">
  </head>
  <body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">
          <img src="/data/images/amongdemons_logo_250x250.png" alt="" class="d-inline-block align-middle me-2 logo-nav" style="width: 48px; height: 48px;">
          Among Demons
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container my-4">
      
      <!-- Header Section: Navigation + Title + Subtitle -->
      <div class="d-flex justify-content-between align-items-center py-3 mb-4">
        <% if (currentPage > 1) { %>
          <a class="text-decoration-none ps-2" href="/demons/type/<%= currentPage - 1 %>" style="font-size: 2rem; line-height: 1;">&laquo;</a>
        <% } else { %>
          <div style="font-size: 2rem; line-height: 1;" class="ps-2">&nbsp;&nbsp;&nbsp;</div>
        <% } %>
        
        <div style="text-align: center;">
          <h1 class="display-4"><%= demonName %></h1>
          <p class="mb-0 text-muted m-0">Demon Type <%= currentPage %></p>
        </div>
        
        <% if (currentPage < totalPages) { %>
          <a class="text-decoration-none pe-2" href="/demons/type/<%= currentPage + 1 %>" style="font-size: 2rem; line-height: 1;">&raquo;</a>
        <% } else { %>
          <div style="font-size: 2rem; line-height: 1;" class="pe-2">&nbsp;&nbsp;&nbsp;</div>
        <% } %>
      </div>

      <!-- Demons Grid -->
      <div class="row row-cols-3 g-3">
        <% for (let i = startImage; i <= endImage; i++) { %>
          <div class="col">
            <div class="card h-100">
              <% const rarity = getRarity(i); %>
              <img src="<%= CONFIG.imagesDir %><%= i %>.png" class="card-img-top" alt="<%= rarity %>" style="width: 100%; height: auto;">
              <div class="card-body text-center">
                <h5 class="card-title m-0 ad-<%= rarity %>"><%= capitalize(rarity) %></h5>
              </div>
            </div>
          </div>
        <% } %>
      </div>

    </main>

    <!-- Footer -->
    <footer class="py-3 my-4 border-top">
      <div class="container text-center text-body-secondary">
        <p>&copy; 2026 Among Demons. All rights reserved.</p>
      </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>